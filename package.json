{
  "name": "brightspace-mcp",
  "version": "0.11.4",
  "description": "MCP server for D2L Brightspace (multi-auth, opt-in writes, session cache)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "brightspace",
    "d2l",
    "lms",
    "education",
    "claude"
  ],
  "homepage": "https://github.com/JhostinAleck/brightspace-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JhostinAleck/brightspace-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/JhostinAleck/brightspace-mcp/issues"
  },
  "author": {
    "name": "Jhostin Aleck Sanchez Mora",
    "url": "https://github.com/JhostinAleck"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/JhostinAleck"
  },
  "type": "module",
  "main": "build/cli/main.js",
  "bin": {
    "brightspace-mcp": "build/cli/main.js"
  },
  "files": [
    "build",
    "docker",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:clean": "rm -rf build && tsc && tsc-alias",
    "dev": "tsc --watch",
    "start": "node build/cli/main.js serve",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage && npm run check:deps",
    "test:e2e": "vitest run tests/e2e",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check:deps": "depcruise --config .dependency-cruiser.cjs src",
    "check": "npm-run-all -p lint typecheck test:run check:deps",
    "prepublishOnly": "npm run check && npm run build:clean"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^12.0.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "nock": "^14.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.0",
    "keytar": "^7.9.0",
    "otplib": "^12.0.1",
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
